{
  "name": "rfid-inventory",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "test": "node --test scripts/tailscale/*.test.mjs && pnpm -r test",
    "tailscale:setup": "node scripts/tailscale/tailscale.mjs setup",
    "tailscale:doctor": "node scripts/tailscale/tailscale.mjs doctor"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"],
    "patchedDependencies": {
      "@better-auth/drizzle-adapter@1.6.18": "patches/@better-auth__drizzle-adapter@1.6.18.patch"
    }
  }
}
