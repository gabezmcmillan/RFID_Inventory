{
  "expo": {
    "name": "field",
    "slug": "field",
    "scheme": "rfid.field",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UISupportedExternalAccessoryProtocols": [
          "com.uk.tsl.rfid"
        ],
        "NSCameraUsageDescription": "The camera scans bill of lading documents during check-in and scans QR codes to link this device to your web account."
      },
      "bundleIdentifier": "com.brasfieldgorrie.rfid-field",
      "appleTeamId": "KDEGJ8G33R"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "react-native-document-scanner-plugin"
    ]
  }
}
