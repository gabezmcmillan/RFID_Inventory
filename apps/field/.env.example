# apps/field environment — copy to .env.local and fill in.
# Schema + validation: src/config/env.ts (the single env seam; boot fails loudly
# on a bad config, naming only the variable — never its value).
#
# Expo inlines EXPO_PUBLIC_* vars at build time, so .env.local is read by Metro,
# not at runtime. Missing = the simulator fallback (http://localhost:3000).
# `pnpm tailscale:setup` writes the key below into .env.local automatically from
# your discovered Tailscale origin; you can also set it by hand.

# Default web app origin for the field app (exact http/https origin — no path,
# query, or credentials). Simulator fallback is http://localhost:3000; on a
# physical device use your Tailscale origin (https://<mac>.<tailnet>.ts.net)
# or a production HTTPS URL. .env.local is gitignored.
EXPO_PUBLIC_DEFAULT_SERVER_URL=
