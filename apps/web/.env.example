# apps/web environment — copy to .env.local and fill in.
# Schema + validation: src/lib/env.ts (all reads go through it; boot fails loudly on bad config).
# ZERO vars is a valid dev config: no auth backend, dev bypass off, local SQLite files.

# ── Dev bypass (never works in production builds) ──────────────────────────
# Set to 1 to skip sign-in locally with a fake user.
AUTH_DEV_BYPASS=
AUTH_DEV_BYPASS_NAME=
AUTH_DEV_BYPASS_EMAIL=

# ── Better Auth (offline gate: no secret => no auth backend) ────────────────
# Generate with: openssl rand -base64 32
# BETTER_AUTH_URL is required whenever the secret is set (public origin for
# OAuth callbacks + session cookies).
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Auth database (separate from warehouse data; never syncs to phones).
# Absent => local file .dev-data/auth.db
AUTH_DATABASE_URL=
AUTH_DATABASE_AUTH_TOKEN=
LOCAL_AUTH_DB_PATH=

# ── Microsoft Entra ID SSO (all three required together) ────────────────────
# Entra admin center → App registrations. Tenant ID is mandatory once
# client id+secret are set (otherwise any Microsoft account could sign in).
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# ── Warehouse domain database (Drizzle/Turso) ───────────────────────────────
# Absent => local file .dev-data/web.db
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
LOCAL_DB_PATH=

# ── Field device API origin (separate from web/SSO; NOT Better Auth's URL) ──
# The private Tailscale HTTPS origin the phone reaches for device linking +
# future sync (e.g. https://<machine>.<tailnet>.ts.net). Discovered by
# `pnpm dev:setup` from `tailscale status --json` (Self.DNSName). NEVER set this
# to http://localhost:3000 — it must differ from BETTER_AUTH_URL. Its value is
# local-only/per-developer and is NOT Vercel-managed. An approved reserved
# ngrok HTTPS endpoint is an optional fallback transport.
FIELD_DEVICE_API_ORIGIN=
FIELD_DEVICE_API_TRANSPORT=
