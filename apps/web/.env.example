# apps/web environment — copy to .env.local and fill in.
# Schema + validation: src/lib/env.ts (all reads go through it; boot fails loudly on bad config).
# ZERO vars is a valid dev config: no auth backend, dev bypass off, local SQLite files.

# ── Dev bypass (never works in production builds) ──────────────────────────
# Set to 1 to skip sign-in locally with a fake user.
AUTH_DEV_BYPASS=
AUTH_DEV_BYPASS_NAME=
AUTH_DEV_BYPASS_EMAIL=

# ── Better Auth (offline gate: no secret => no auth backend) ────────────────
# Generate with: openssl rand -base64 32
# BETTER_AUTH_URL is required whenever the secret is set (public origin for
# OAuth callbacks + session cookies).
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Auth database (separate from warehouse data; never syncs to phones).
# Absent => local file .dev-data/auth.db
AUTH_DATABASE_URL=
AUTH_DATABASE_AUTH_TOKEN=
LOCAL_AUTH_DB_PATH=

# ── Microsoft Entra ID SSO (all three required together) ────────────────────
# Entra admin center → App registrations. Tenant ID is mandatory once
# client id+secret are set (otherwise any Microsoft account could sign in).
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# ── Warehouse domain database (Drizzle/Turso) ───────────────────────────────
# Absent => local file .dev-data/web.db
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
LOCAL_DB_PATH=

# ── Plan 010: field device linking + sync + BOL upload (server-only) ───────
# All server-only — NEVER prefix with NEXT_PUBLIC_*/EXPO_PUBLIC_*.
#
# Field-operator allowlist: comma- and/or whitespace-separated emails, matched
# case-insensitively. Gates who may link a field device. Empty/absent => deny all
# (a misconfigured deploy never silently allows linking).
FIELD_OPERATOR_ALLOWLIST=ops@example.com, field-lead@example.com

# Turso Platform API token used to mint short-lived, fine-grained field-sync
# tokens (server seam). Absent in local dev (the credential endpoint returns 503).
TURSO_MINT_TOKEN=
# Mint targets: the Turso org + warehouse DB NAME (as in `turso db list`), not
# the libSQL hostname. Local dev points at the -dev warehouse DB.
TURSO_ORG=
TURSO_DB_NAME=

# Vercel Blob read-write token for the `rfid-bol` store (BOL page artifacts).
# Absent in local dev (the BOL upload-grant endpoint returns 503). The store is
# private; uploads use presigned PUT URLs, the tag page mints a presigned GET.
BLOB_READ_WRITE_TOKEN=
